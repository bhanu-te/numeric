sql -- 1. Name with 'A' at 2nd position 
SELECT * FROM EMP WHERE ENAME LIKE '_A%'; -- 2. Names + salaries with 'L' at 2nd position 
SELECT ENAME, SAL FROM EMP WHERE ENAME LIKE '_L%'; -- 3. Names ending with 'S' 
SELECT * FROM EMP WHERE ENAME LIKE '%S'; -- 4. Names containing 'A' exactly two times 
SELECT * FROM EMP WHERE ENAME LIKE '%A%A%' AND ENAME NOT LIKE 
'%A%A%A%'; -- 5. Second character 'A' 
SELECT * FROM EMP WHERE ENAME LIKE '_A%'; -- 6. Third character 'R' 
SELECT ENAME FROM EMP WHERE ENAME LIKE '__R%'; -- 7. First char 'S' and second 'M' 
SELECT * FROM EMP WHERE ENAME LIKE 'SM%'; -- 8. Last char 'N' and second last 'O' 
SELECT ENAME FROM EMP WHERE ENAME LIKE '%ON'; -- 9. Fourth char 'T' 
SELECT * FROM EMP WHERE ENAME LIKE '___T%'; -- 10. Fifth char 'H' 
SELECT * FROM EMP WHERE ENAME LIKE '____H%'; -- 11. Names contain 'A' but not ending with 'A' 
SELECT * FROM EMP WHERE ENAME LIKE '%A%' AND ENAME NOT LIKE '%A'; 
-- 12. Salary with 4 digits 
